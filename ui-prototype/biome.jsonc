{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    "includes": [
      "!archive",
      "!artifacts",
      "!dist",
      "!node_modules",
      "!src/components/ui",
      "!src/hooks",
      "!public/provider-brand-candidates"
    ]
  },
  "linter": {
    "rules": {
      "performance": {
        "noJsxPropsBind": "off"
      }
    }
  }
}
