{
  "expo": {
    "name": "TimberVox",
    "slug": "timbervox-ios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "timbervox",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/timbervox-icon.png",
      "bundleIdentifier": "studio.peacockery.timbervox",
      "buildNumber": "94",
      "appleTeamId": "XM69J99HWP",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "TimberVox records your voice while a dictation session is active.",
        "NSSupportsLiveActivities": true,
        "UIBackgroundModes": ["audio"]
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.studio.peacockery.timbervox"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1e130a",
          "image": "./assets/images/timbervox-icon.png",
          "imageWidth": 160
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow TimberVox to record audio for transcription.",
          "enableBackgroundRecording": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.0",
            "extraPods": [
              {
                "name": "FluidAudio",
                "git": "https://github.com/FluidInference/FluidAudio.git",
                "tag": "v0.15.5"
              }
            ]
          }
        }
      ],
      "expo-sqlite",
      [
        "react-native-nano-icons",
        {
          "iconSets": [
            {
              "fontFamily": "TimberVoxProviders",
              "inputDir": "../../Shared/ProviderIcons",
              "outputDir": "./assets/icons/nanoicons"
            }
          ]
        }
      ],
      "./plugins/with-timbervox-app-shortcuts",
      "./plugins/with-executorch-keyboard",
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "studio.peacockery.timbervox.keyboard",
                  "targetName": "TimberVoxKeyboard",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.studio.peacockery.timbervox"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "studio.peacockery.timbervox.app-intents",
                  "targetName": "TimberVoxAppIntents",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.studio.peacockery.timbervox"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "studio.peacockery.timbervox.recording-activity",
                  "targetName": "TimberVoxRecordingActivity",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.studio.peacockery.timbervox"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "daa3207f-0de1-461d-8c79-1928a60a05ec"
      }
    },
    "owner": "peacockery-studio"
  }
}
