{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "TIMBERVOX_EMBED_DEV_CREDENTIAL": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "TIMBERVOX_EMBED_DEV_CREDENTIAL": "1"
      }
    },
    "testflight-dev": {
      "distribution": "store",
      "environment": "preview",
      "autoIncrement": true,
      "env": {
        "TIMBERVOX_EMBED_DEV_CREDENTIAL": "1"
      }
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "TIMBERVOX_EMBED_DEV_CREDENTIAL": "0"
      }
    }
  },
  "submit": {
    "testflight-dev": {},
    "production": {}
  }
}
