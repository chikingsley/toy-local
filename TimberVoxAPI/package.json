{
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "knip": "^6.27.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "ultracite": "^7.9.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0",
    "ws": "^8.21.1"
  },
  "scripts": {
    "benchmark:text": "TIMBERVOX_API_KEY=${TIMBERVOX_API_KEY:-$(sed -n 's/^TIMBERVOX_API_KEY = //p' ../Config/keys/TimberVoxAPI.local.xcconfig)} tsx scripts/benchmark-text.ts",
    "check": "wrangler types --check && ultracite check && tsc --noEmit",
    "dev": "wrangler dev --remote",
    "fix": "ultracite fix",
    "knip": "knip",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:integration": "TIMBERVOX_API_KEY=${TIMBERVOX_API_KEY:-$(sed -n 's/^TIMBERVOX_API_KEY = //p' ../Config/keys/TimberVoxAPI.local.xcconfig)} vitest run --config vitest.cloud.config.ts",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:realtime-live": "vitest run tests/live/realtime-contract.test.ts --config vitest.live.config.ts",
    "types:worker": "wrangler types",
    "types:worker:check": "wrangler types --check"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/cerebras": "^3.0.12",
    "@ai-sdk/deepseek": "^3.0.12",
    "@ai-sdk/google": "^4.0.18",
    "@ai-sdk/groq": "^4.0.12",
    "@ai-sdk/mistral": "^4.0.13",
    "@ai-sdk/openai": "^4.0.16",
    "@ai-sdk/provider": "^4.0.3",
    "@chikingsley/superwhisper-provider": "github:chikingsley/superwhisper-api#3807c9d5419ebf063993a5dfc44b6b6422f3110c&path:/superwhisper-provider",
    "@hono/zod-openapi": "^1.5.1",
    "@scalar/hono-api-reference": "^0.11.11",
    "ai": "^7.0.31",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.30",
    "zhipu-ai-provider": "^0.3.1",
    "zod": "^4.4.3"
  }
}
